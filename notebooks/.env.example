# ============================================================
# BEST Agentic AI Summer Course — API Keys
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your API keys below
# 3. Keep .env secret — it's git-ignored
# ============================================================

# OpenRouter (default provider for this course)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (alternative provider)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (used in Notebook 00, 03, 04)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek (used in Notebook 00)
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
